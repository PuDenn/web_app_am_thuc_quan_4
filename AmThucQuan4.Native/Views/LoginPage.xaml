<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AmThucQuan4.Native.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0f172a">

  <ScrollView>
    <VerticalStackLayout Padding="32"
                         VerticalOptions="Center"
                         Spacing="0">

      <!-- Logo -->
      <Label Text="🍜"
             FontSize="64"
             HorizontalOptions="Center"
             Margin="0,40,0,8" />

      <Label Text="Ẩm Thực Quận 4"
             FontSize="28"
             FontAttributes="Bold"
             TextColor="#f97316"
             HorizontalOptions="Center" />

      <Label Text="Khám phá ẩm thực đường phố Sài Gòn"
             FontSize="14"
             TextColor="#64748b"
             HorizontalOptions="Center"
             Margin="0,4,0,40" />

      <!-- Tab Login / Register -->
      <Grid ColumnDefinitions="*,*"
            Margin="0,0,0,24">
        <Button x:Name="btnLoginTab"
                Grid.Column="0"
                Text="Đăng nhập"
                Clicked="OnLoginTabClicked"
                BackgroundColor="#f97316"
                TextColor="White"
                CornerRadius="12"
                FontAttributes="Bold" />
        <Button x:Name="btnRegisterTab"
                Grid.Column="1"
                Text="Đăng ký"
                Clicked="OnRegisterTabClicked"
                BackgroundColor="#1e293b"
                TextColor="#94a3b8"
                CornerRadius="12" />
      </Grid>

      <!-- Form Login -->
      <VerticalStackLayout x:Name="loginForm" Spacing="12">

        <Border BackgroundColor="#1e293b"
                StrokeShape="RoundRectangle 12"
                Stroke="#334155"
                Padding="16,4">
          <Entry x:Name="txtUsername"
                 Placeholder="Tên đăng nhập"
                 PlaceholderColor="#475569"
                 TextColor="White"
                 BackgroundColor="Transparent"
                 ReturnType="Next" />
        </Border>

        <Border BackgroundColor="#1e293b"
                StrokeShape="RoundRectangle 12"
                Stroke="#334155"
                Padding="16,4">
          <Entry x:Name="txtPassword"
                 Placeholder="Mật khẩu"
                 PlaceholderColor="#475569"
                 TextColor="White"
                 BackgroundColor="Transparent"
                 IsPassword="True"
                 ReturnType="Done"
                 ReturnCommand="{x:Null}" />
        </Border>

        <Label x:Name="lblError"
               TextColor="#ef4444"
               FontSize="13"
               HorizontalOptions="Center"
               IsVisible="False" />

        <Button Text="Đăng nhập"
                Clicked="OnLoginClicked"
                BackgroundColor="#f97316"
                TextColor="White"
                CornerRadius="14"
                FontAttributes="Bold"
                HeightRequest="52"
                Margin="0,8,0,0" />

        <ActivityIndicator x:Name="loadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           Color="#f97316"
                           HorizontalOptions="Center" />
      </VerticalStackLayout>

      <!-- Form Register (ẩn mặc định) -->
      <VerticalStackLayout x:Name="registerForm"
                           IsVisible="False"
                           Spacing="12">

        <Border BackgroundColor="#1e293b"
                StrokeShape="RoundRectangle 12"
                Stroke="#334155"
                Padding="16,4">
          <Entry x:Name="txtRegUsername"
                 Placeholder="Tên đăng nhập"
                 PlaceholderColor="#475569"
                 TextColor="White"
                 BackgroundColor="Transparent" />
        </Border>

        <Border BackgroundColor="#1e293b"
                StrokeShape="RoundRectangle 12"
                Stroke="#334155"
                Padding="16,4">
          <Entry x:Name="txtRegEmail"
                 Placeholder="Email"
                 PlaceholderColor="#475569"
                 TextColor="White"
                 BackgroundColor="Transparent"
                 Keyboard="Email" />
        </Border>

        <Border BackgroundColor="#1e293b"
                StrokeShape="RoundRectangle 12"
                Stroke="#334155"
                Padding="16,4">
          <Entry x:Name="txtRegPassword"
                 Placeholder="Mật khẩu (ít nhất 6 ký tự)"
                 PlaceholderColor="#475569"
                 TextColor="White"
                 BackgroundColor="Transparent"
                 IsPassword="True" />
        </Border>

        <Label x:Name="lblRegError"
               TextColor="#ef4444"
               FontSize="13"
               HorizontalOptions="Center"
               IsVisible="False" />

        <Button Text="Đăng ký"
                Clicked="OnRegisterClicked"
                BackgroundColor="#7c3aed"
                TextColor="White"
                CornerRadius="14"
                FontAttributes="Bold"
                HeightRequest="52"
                Margin="0,8,0,0" />
      </VerticalStackLayout>

      <!-- Demo hint -->
      <Label Text="Demo: admin / Admin@123"
             TextColor="#334155"
             FontSize="12"
             HorizontalOptions="Center"
             Margin="0,24,0,0" />

    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
