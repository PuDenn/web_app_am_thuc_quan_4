<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ẩm Thực Quận 4</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#E65100" />
</head>
<body>

<!-- Loading -->
<div id="loading"><div class="spinner"></div></div>

<!-- Error -->
<div id="error" class="error-box" style="display:none">
  <div style="font-size:48px">😕</div>
  <h2>Không tìm thấy quán</h2>
  <p id="errorMsg">Vui lòng thử lại hoặc kiểm tra kết nối mạng và API</p>
  <p style="font-size:12px;color:#475569;margin-top:8px" id="debugInfo"></p>
</div>

<!-- Main app -->
<div id="app" style="display:none">

  <!-- TAB: THÔNG TIN -->
  <div id="tab-info" class="tab-content active">
    <div class="hero">
      <img id="poiImage" src="" alt=""
           onerror="this.src='https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=600'" />
      <div class="hero-overlay"></div>
      <div class="hero-title" id="poiName"></div>
    </div>
    <div class="info-card">
      <div class="chips">
        <span class="chip" id="chipCategory"></span>
        <span class="chip" id="chipHours">⏰ --</span>
        <span class="chip" id="chipPrice">💰 --</span>
      </div>
      <p style="font-size:13px;color:var(--text-muted)" id="poiAddress"></p>
    </div>
    <div class="info-card">
      <p class="desc collapsed" id="poiDesc"></p>
      <button class="expand-btn" id="expandBtn" onclick="toggleDesc()">Xem thêm ▼</button>
    </div>
  </div>

  <!-- TAB: AUDIO -->
  <div id="tab-audio" class="tab-content">
    <div class="audio-player">
      <p class="audio-title" id="audioTitle">🎙️ Thuyết minh</p>
      <button class="play-btn" id="playBtn" onclick="togglePlay()">▶</button>
      <p style="font-size:12px;color:var(--text-muted);margin-top:16px">
        🔊 Nhấn ▶ để nghe thuyết minh bằng giọng đọc thiết bị
      </p>
      <button class="back10-btn" id="back10Btn" onclick="stopAudio()" title="Dừng">⏹ Dừng</button>
    </div>
  </div>

  <!-- TAB: BẢN ĐỒ -->
  <div id="tab-map" class="tab-content">
    <div id="map"></div>
  </div>

  <!-- Bottom Navigation -->
  <nav class="bottom-nav">
    <button class="nav-btn active" onclick="switchTab('info', this)">
      <span class="nav-icon">ℹ️</span>Thông tin
    </button>
    <button class="nav-btn" onclick="switchTab('audio', this)">
      <span class="nav-icon">🎙️</span>Audio
    </button>
    <button class="nav-btn" onclick="switchTab('map', this)">
      <span class="nav-icon">🗺️</span>Bản đồ
    </button>
  </nav>
</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
// ── Config ────────────────────────────────────────────
// Tự động dùng localhost nếu mở trên máy tính
var API_BASE = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
  ? 'http://localhost:5000'
  : 'http://' + location.hostname + ':5000';

// ── State ─────────────────────────────────────────────
var currentPoi   = null;
var isPlaying    = false;
var utterance    = null;

// ── Init ──────────────────────────────────────────────
var params = new URLSearchParams(location.search);
var poiId  = params.get('id');

if (!poiId) {
  showError('Thiếu tham số ?id= trong URL', '');
} else {
  loadPoi(poiId);
}

async function loadPoi(id) {
  var url = API_BASE + '/api/pois/' + id;
  document.getElementById('debugInfo') &&
    (document.getElementById('debugInfo').textContent = 'Đang gọi: ' + url);
  try {
    var res = await fetch(url);
    if (!res.ok) throw new Error('HTTP ' + res.status + ' — ' + url);
    var poi = await res.json();
    currentPoi = poi;
    renderPoi(poi);
    logEvent(id, 'qr_scan');
    logEvent(id, 'view');
  } catch(e) {
    showError(e.message, 'URL đang gọi: ' + url);
  }
}

function renderPoi(poi) {
  document.title = poi.name + ' — Ẩm Thực Quận 4';
  document.getElementById('poiName').textContent    = poi.name || '';
  document.getElementById('poiImage').src           = poi.imageUrl || '';
  document.getElementById('poiAddress').textContent = '📌 ' + (poi.address || '');
  document.getElementById('poiDesc').textContent    = poi.description || '';
  document.getElementById('chipCategory').textContent = (poi.categoryIcon||'🍽️') + ' ' + (poi.category||'');
  document.getElementById('chipHours').textContent  = '⏰ ' + (poi.hours||'--');
  document.getElementById('chipPrice').textContent  = '💰 ' + (poi.priceRange||'--');
  document.getElementById('audioTitle').textContent = '🎙️ ' + poi.name;

  // Map
  if (poi.latitude && poi.longitude) {
    renderMap(poi.latitude, poi.longitude, poi.name);
  }

  document.getElementById('loading').style.display = 'none';
  document.getElementById('app').style.display     = 'block';
}

function renderMap(lat, lng, name) {
  var map = L.map('map').setView([lat, lng], 17);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap'
  }).addTo(map);
  var icon = L.divIcon({
    className: '',
    html: '<div style="width:36px;height:36px;border-radius:50%;background:#f97316;border:3px solid white;display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 2px 8px rgba(0,0,0,.4)">🍽️</div>',
    iconSize: [36, 36], iconAnchor: [18, 18],
  });
  L.marker([lat, lng], { icon }).addTo(map).bindPopup('<b>' + name + '</b>').openPopup();
}

// ── Audio TTS ─────────────────────────────────────────
function togglePlay() {
  if (!currentPoi) return;
  var script = currentPoi.audioScript || currentPoi.description || currentPoi.name;
  if (isPlaying) {
    stopAudio(); return;
  }
  utterance = new SpeechSynthesisUtterance(script);
  utterance.lang = 'vi-VN';
  utterance.rate = 0.9;
  utterance.onend = function() {
    isPlaying = false;
    document.getElementById('playBtn').textContent = '▶';
    document.getElementById('playBtn').classList.remove('playing-anim');
  };
  window.speechSynthesis.speak(utterance);
  isPlaying = true;
  document.getElementById('playBtn').textContent = '⏸';
  document.getElementById('playBtn').classList.add('playing-anim');
  logEvent(poiId, 'audio_play');
}

function stopAudio() {
  window.speechSynthesis.cancel();
  isPlaying = false;
  var btn = document.getElementById('playBtn');
  if (btn) { btn.textContent = '▶'; btn.classList.remove('playing-anim'); }
}

// ── Tab switch ────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-content').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  if (name !== 'audio') stopAudio();
}

// ── Expand description ────────────────────────────────
function toggleDesc() {
  var desc = document.getElementById('poiDesc');
  var btn  = document.getElementById('expandBtn');
  desc.classList.toggle('collapsed');
  btn.textContent = desc.classList.contains('collapsed') ? 'Xem thêm ▼' : 'Thu gọn ▲';
}

// ── Log event ─────────────────────────────────────────
function logEvent(id, type) {
  fetch(API_BASE + '/api/log', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ poiId: parseInt(id), type: type, source: 'web' })
  }).catch(function() {});
}

// ── Error ─────────────────────────────────────────────
function showError(msg, debug) {
  document.getElementById('loading').style.display = 'none';
  document.getElementById('error').style.display   = 'block';
  document.getElementById('errorMsg').textContent  = msg;
  if (debug && document.getElementById('debugInfo'))
    document.getElementById('debugInfo').textContent = debug;
}
</script>
</body>
</html>
